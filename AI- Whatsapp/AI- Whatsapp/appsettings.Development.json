{
  "AI": {
    "Provider": "Ollama",
    "DebugModeEnabled": true,
    "OllamaEndpoint": "http://localhost:11434",
    "OllamaModel": "llama3.1:8b",
    "OpenAIModel": "gpt-4o-mini",
    "GeminiModel": "gemini-1.5-flash",
    "RequestTimeoutSeconds": 60,
    "OpenAIApiKey": "",
    "GeminiApiKey": ""
  },
  "Authentication": {
    "Jwt": {
      "Issuer": "EcomAI.Platform",
      "Audience": "EcomAI.Platform.Clients",
      "SigningKey": "CHANGE_THIS_IN_USER_SECRETS_MIN_32_CHARS",
      "AccessTokenLifetimeMinutes": 30,
      "RefreshTokenLifetimeDays": 14,
      "PasswordResetTokenLifetimeMinutes": 30
    }
  },
  "MetaOAuth": {
    "AppId": "",
    "AppSecret": "",
    "CallbackBaseUrl": "",
    "GraphVersion": "25.0",
    "StateLifetimeMinutes": 10,
    "LoginConfigurationId": ""
  },
  "Bootstrap": {
    "EnableBootstrapSeeding": true,
    "CreateHostTenantIfMissing": true,
    "HostTenantId": null,
    "HostTenantName": "host-tenant",
    "HostBusinessName": "Host Tenant",
    "SuperUserFirstName": "Host",
    "SuperUserLastName": "Admin"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
